# Copy this file to .env and update the values before running docker-compose.
# Do NOT commit your .env file to version control.

# PostgreSQL credentials (used by both isley and postgres services)
ISLEY_DB_USER=isley
ISLEY_DB_PASSWORD=changeme
ISLEY_DB_NAME=isleydb

# Session secret — set to a long random string for production
# Sessions will not survive container restarts without this.
ISLEY_SESSION_SECRET=change-me-to-a-long-random-string
